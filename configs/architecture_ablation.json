{
  "_comment": "Architecture ablation on AMI. Each variant changes ONE knob from the default config to isolate its effect on test WER. The 8 variants correspond to the rows of Table 'Architecture ablation' in the manuscript.",
  "parquet_path": "data/processed/edinburghcstr_ami/combined_features_with_transcripts.parquet",
  "shared": {
    "arch": "hierarchical_transformer",
    "train_ratio": 0.8,
    "val_ratio": 0.1,
    "max_seq_len": 2000,
    "batch_size": 8,
    "num_workers": 0,
    "max_epochs": 50,
    "learning_rate": 1e-4,
    "primary_weight": 1.0,
    "aux_ce_weight": 0.0,
    "soft_ce_weight": 0.5,
    "soft_ce_temperature": 0.1,
    "seed": 42
  },
  "variants": [
    { "name": "default" },
    { "name": "no_bridge",       "no_cross_attention": true },
    { "name": "separate_stage1", "separate_stage1": true },
    { "name": "stage1_layers_1", "stage1_layers": 1 },
    { "name": "stage1_layers_4", "stage1_layers": 4 },
    { "name": "stage2_layers_2", "stage2_layers": 2 },
    { "name": "d_model_128",     "d_model": 128, "ffn_dim": 256 },
    { "name": "d_model_512",     "d_model": 512, "ffn_dim": 1024 }
  ]
}
