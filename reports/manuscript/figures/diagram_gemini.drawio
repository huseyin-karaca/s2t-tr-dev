        <mxCell id="sel_tr" style="endArrow=classic;html=1;rounded=0;strokeWidth=1.5;strokeColor=#000000;" edge="1" parent="1" source="selected" target="trans"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="train_box" value="Training (offline)&#10;each $A_k$ is run on $x_n$ to obtain&#10;$T_{n,k}$ and $\mathrm{WER}_{n,k}$;&#10;loss in (\ref{eq:total_objective})." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;strokeWidth=1.5;fontSize=12;dashed=1;align=center;fontStyle=2;fontFamily=Times New Roman;" vertex="1" parent="1">
          <mxGeometry x="1220" y="1130" width="380" height="100" as="geometry" />
        </mxCell>

        <mxCell id="legend" value="Diagram structure:&#10;Gray backgrounds indicate multi-dimensional embeddings and network inputs/outputs.&#10;White boxes with solid borders denote deterministic network operations (projections, linear layers, transformers).&#10;Dashed borders represent offline mechanisms or optional architectural pathways." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#666666;strokeWidth=1;fontSize=11;align=left;fontFamily=Times New Roman;" vertex="1" parent="1">
          <mxGeometry x="40" y="1330" width="540" height="80" as="geometry" />
