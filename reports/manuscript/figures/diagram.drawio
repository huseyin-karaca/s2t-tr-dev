        <mxCell id="enc2" value="&lt;b&gt;Whisper-base&lt;/b&gt; encoder&lt;br&gt;hidden dim D&lt;sub&gt;2&lt;/sub&gt; = 512" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="640" y="160" width="220" height="60" as="geometry" />
        </mxCell>
        <mxCell id="enc3" value="&lt;b&gt;W2V2-Large-Robust&lt;/b&gt; encoder&lt;br&gt;hidden dim D&lt;sub&gt;3&lt;/sub&gt; = 1024" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1160" y="160" width="220" height="60" as="geometry" />
        </mxCell>

        <mxCell id="ea1" style="endArrow=classic;html=1;rounded=0;exitX=0.25;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="audio" target="enc1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ea2" style="endArrow=classic;html=1;rounded=0;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="audio" target="enc2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ea3" style="endArrow=classic;html=1;rounded=0;exitX=0.75;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="audio" target="enc3"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- ========== 2-D frame-level embedding tensors ========== -->
        <!-- HuBERT: wide -->
        <mxCell id="emb1" value="&lt;b&gt;Frame-level embedding&lt;/b&gt;&lt;br&gt;shape: T&lt;sub&gt;1&lt;/sub&gt; × 1024" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;verticalAlign=top;spacingTop=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="270" width="340" height="120" as="geometry" />
        </mxCell>
        <mxCell id="emb1g1" value="" style="endArrow=none;html=1;strokeColor=#9673a6;dashed=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="120" y="320" as="sourcePoint" /><mxPoint x="120" y="390" as="targetPoint" /></mxGeometry>
