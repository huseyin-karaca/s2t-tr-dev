        <mxCell id="emb3g4" value="" style="endArrow=none;html=1;strokeColor=#9673a6;dashed=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1380" y="320" as="sourcePoint" /><mxPoint x="1380" y="390" as="targetPoint" /></mxGeometry>
        </mxCell>

        <!-- Encoder -> embedding edges -->
        <mxCell id="ee1" style="endArrow=classic;html=1;rounded=0;" edge="1" parent="1" source="enc1" target="emb1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ee2" style="endArrow=classic;html=1;rounded=0;" edge="1" parent="1" source="enc2" target="emb2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ee3" style="endArrow=classic;html=1;rounded=0;" edge="1" parent="1" source="enc3" target="emb3"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- Note about variable D_k -->
        <mxCell id="note2d" value="2-D frame-level tensors are preserved (no temporal pooling). Each encoder may have a different hidden dimension D&lt;sub&gt;k&lt;/sub&gt; and frame count T&lt;sub&gt;k&lt;/sub&gt;." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;dashed=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="380" y="410" width="740" height="40" as="geometry" />
        </mxCell>

        <!-- ========== Stage 1 (single shared box) ========== -->
        <mxCell id="stage1" value="&lt;b&gt;Stage 1 — Per-Expert Temporal Encoder&lt;/b&gt;&lt;br&gt;Per-encoder linear projection W&lt;sub&gt;p&lt;/sub&gt;&lt;sup&gt;(k)&lt;/sup&gt;: ℝ&lt;sup&gt;D&lt;sub&gt;k&lt;/sub&gt;&lt;/sup&gt; → ℝ&lt;sup&gt;d&lt;/sup&gt; · sinusoidal positional encoding · model-identity embedding e&lt;sub&gt;k&lt;/sub&gt;&lt;br&gt;Shared-weight Transformer encoder applied independently to each expert's projected sequence; output of the prepended CLS token serves as the per-expert summary." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;verticalAlign=middle;align=center;" vertex="1" parent="1">
          <mxGeometry x="120" y="490" width="1260" height="100" as="geometry" />
        </mxCell>

        <mxCell id="es1a" style="endArrow=classic;html=1;rounded=0;" edge="1" parent="1" source="emb1" target="stage1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="es1b" style="endArrow=classic;html=1;rounded=0;" edge="1" parent="1" source="emb2" target="stage1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="es1c" style="endArrow=classic;html=1;rounded=0;" edge="1" parent="1" source="emb3" target="stage1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- ========== Per-expert summaries (three small ellipses) ========== -->
        <mxCell id="h1" value="summary&lt;br&gt;c&#771;&lt;sub&gt;1&lt;/sub&gt;" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="220" y="630" width="120" height="50" as="geometry" />
        </mxCell>
        <mxCell id="h2" value="summary&lt;br&gt;c&#771;&lt;sub&gt;2&lt;/sub&gt;" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="690" y="630" width="120" height="50" as="geometry" />
        </mxCell>
        <mxCell id="h3" value="summary&lt;br&gt;c&#771;&lt;sub&gt;3&lt;/sub&gt;" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1160" y="630" width="120" height="50" as="geometry" />
        </mxCell>

        <mxCell id="s1h1" style="endArrow=classic;html=1;rounded=0;exitX=0.2;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="stage1" target="h1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="s1h2" style="endArrow=classic;html=1;rounded=0;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="stage1" target="h2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="s1h3" style="endArrow=classic;html=1;rounded=0;exitX=0.8;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="stage1" target="h3"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- ========== Cross-attention bridge (optional) ========== -->
        <mxCell id="bridge" value="&lt;b&gt;Cross-attention bridge&lt;/b&gt; (optional) — each summary c&#771;&lt;sub&gt;k&lt;/sub&gt; attends to the frame-level outputs of the other experts" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fad9d5;strokeColor=#ae4132;fontSize=12;dashed=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="220" y="710" width="1060" height="40" as="geometry" />
        </mxCell>
        <mxCell id="bh1" style="endArrow=classic;html=1;rounded=0;dashed=1;exitX=0.1;exitY=0;entryX=0.5;entryY=1;" edge="1" parent="1" source="bridge" target="h1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="bh2" style="endArrow=classic;html=1;rounded=0;dashed=1;exitX=0.5;exitY=0;entryX=0.5;entryY=1;" edge="1" parent="1" source="bridge" target="h2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="bh3" style="endArrow=classic;html=1;rounded=0;dashed=1;exitX=0.9;exitY=0;entryX=0.5;entryY=1;" edge="1" parent="1" source="bridge" target="h3"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- ========== Stage 2 (single fusion box) ========== -->
        <mxCell id="stage2" value="&lt;b&gt;Stage 2 — Cross-Expert Fusion&lt;/b&gt;&lt;br&gt;Transformer encoder over (global CLS, c&#771;&lt;sub&gt;1&lt;/sub&gt;, c&#771;&lt;sub&gt;2&lt;/sub&gt;, c&#771;&lt;sub&gt;3&lt;/sub&gt;) → updated global CLS" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d4e1f5;strokeColor=#3b6ec3;fontSize=12;align=center;" vertex="1" parent="1">
          <mxGeometry x="320" y="780" width="860" height="60" as="geometry" />
        </mxCell>

        <mxCell id="hs2a" style="endArrow=classic;html=1;rounded=0;" edge="1" parent="1" source="h1" target="stage2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="hs2b" style="endArrow=classic;html=1;rounded=0;" edge="1" parent="1" source="h2" target="stage2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="hs2c" style="endArrow=classic;html=1;rounded=0;" edge="1" parent="1" source="h3" target="stage2"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- ========== Classifier ========== -->
        <mxCell id="cls" value="&lt;b&gt;MLP classifier → softmax → argmax&lt;/b&gt;&lt;br&gt;routing distribution w over K experts; selected expert index j" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d4e1f5;strokeColor=#3b6ec3;fontSize=12;align=center;" vertex="1" parent="1">
          <mxGeometry x="450" y="870" width="600" height="60" as="geometry" />
        </mxCell>
        <mxCell id="s2cls" style="endArrow=classic;html=1;rounded=0;" edge="1" parent="1" source="stage2" target="cls"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- ========== Decode + final output ========== -->
        <mxCell id="decode" value="&lt;b&gt;Decode only A&lt;sub&gt;j&lt;/sub&gt;(x)&lt;/b&gt; (run the full STT pipeline of the chosen expert) → final transcription T&#770;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="400" y="960" width="700" height="60" as="geometry" />
        </mxCell>
        <mxCell id="cls_dec" style="endArrow=classic;html=1;rounded=0;" edge="1" parent="1" source="cls" target="decode"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- ========== Color legend ========== -->
        <mxCell id="legend" value="&lt;b&gt;Legend&lt;/b&gt;: yellow = pretrained encoders · purple = 2-D frame-level embeddings · pink = Stage 1 (per-expert) and bridge · blue = summaries / Stage 2 / classifier · green = decoded expert" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;align=left;" vertex="1" parent="1">
          <mxGeometry x="60" y="1040" width="1380" height="30" as="geometry" />
