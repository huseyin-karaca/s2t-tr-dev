        <mxCell id="emb3g2" value="" style="endArrow=none;html=1;strokeColor=#9673a6;dashed=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1240" y="320" as="sourcePoint" /><mxPoint x="1240" y="390" as="targetPoint" /></mxGeometry>
        </mxCell>
        <mxCell id="emb3g3" value="" style="endArrow=none;html=1;strokeColor=#9673a6;dashed=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1320" y="320" as="sourcePoint" /><mxPoint x="1320" y="390" as="targetPoint" /></mxGeometry>
