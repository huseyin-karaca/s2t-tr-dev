          <mxGeometry relative="1" as="geometry"><mxPoint x="800" y="320" as="sourcePoint" /><mxPoint x="800" y="390" as="targetPoint" /></mxGeometry>
        </mxCell>

        <!-- W2V2: wide -->
        <mxCell id="emb3" value="&lt;b&gt;Frame-level embedding&lt;/b&gt;&lt;br&gt;shape: T&lt;sub&gt;3&lt;/sub&gt; × 1024" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;verticalAlign=top;spacingTop=10;" vertex="1" parent="1">
          <mxGeometry x="1100" y="270" width="340" height="120" as="geometry" />
        </mxCell>
        <mxCell id="emb3g1" value="" style="endArrow=none;html=1;strokeColor=#9673a6;dashed=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1160" y="320" as="sourcePoint" /><mxPoint x="1160" y="390" as="targetPoint" /></mxGeometry>
