          <mxGeometry x="680" y="70" width="140" height="50" as="geometry" />
        </mxCell>

        <!-- ========== Three base encoders ========== -->
        <mxCell id="enc1" value="&lt;b&gt;HuBERT-Large&lt;/b&gt; encoder&lt;br&gt;hidden dim D&lt;sub&gt;1&lt;/sub&gt; = 1024" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="120" y="160" width="220" height="60" as="geometry" />
